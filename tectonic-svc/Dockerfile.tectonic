FROM alpine:3.19

# Install Tectonic and its runtime dependencies
RUN apk add --no-cache \
    curl \
    fontconfig \
    harfbuzz \
    openssl \
    nodejs \
    npm

# Install Tectonic binary
RUN curl -fsSL https://github.com/tectonic-typesetting/tectonic/releases/download/tectonic%400.15.0/tectonic-0.15.0-x86_64-unknown-linux-musl.tar.gz \
    | tar -xz -C /usr/local/bin

WORKDIR /app

# Tiny Node.js HTTP server that accepts POST /compile (LaTeX body) → returns PDF
COPY dist/tectonic-server.js ./tectonic-server.js
RUN npm init -y

EXPOSE 4000
CMD ["node", "tectonic-server.js"]
