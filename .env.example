# ===== REQUIRED: OpenCode Server =====
OPENCODE_HOSTNAME=localhost
OPENCODE_PORT=4096
OPENCODE_SERVER_PASSWORD=your-opencode-server-password

# ===== REQUIRED: Resume Profile =====
RESUME_NAME=Your Full Name
RESUME_PHONE=+1234567890
RESUME_EMAIL=your.email@example.com
RESUME_LINKEDIN_URL=https://www.linkedin.com/in/your-handle
RESUME_LINKEDIN_DISPLAY=linkedin.com/in/your-handle
# RESUME_GITHUB_URL=https://github.com/your-handle
# RESUME_GITHUB_DISPLAY=github.com/your-handle

# ===== REQUIRED: Education =====
EDU1_INSTITUTION=University Name
EDU1_LOCATION=City, Country
EDU1_DEGREE=Masters in XYZ
EDU1_DATES=Month 202x - Month 202x

EDU2_INSTITUTION=University Name
EDU2_LOCATION=City, Country
EDU2_DEGREE=Bachelors in XYZ
EDU2_DATES=202x - 202x

# ===== OPTIONAL: Model Overrides =====
# OPENCODE_MODEL=opencode-go/minimax-m2.7
# OPENCODE_MODEL_PROVIDER_ID=opencode-go
# OPENCODE_MODEL_ID=minimax-m2.7

# ===== OPTIONAL: AI Concurrency =====
# Max parallel AI requests per model. Excess requests queue and wait.
# Default is 1 (strictly serial per model). Raise to 2 or 3 to run more
# generations in parallel — note this can hit upstream provider rate limits.
# OPENCODE_AI_CONCURRENCY=1

# ===== OPTIONAL: AI Queue =====
# Set to false to disable the per-model queue entirely. Every call runs
# immediately with no slot cap (OPENCODE_AI_CONCURRENCY is ignored).
# Use this when you want maximum throughput and trust upstream rate limits.
# Default is true.
# OPENCODE_AI_QUEUE=true

# ===== OPTIONAL: AI Prompt Timeout =====
# Upper bound for a single client.session.prompt fetch. Fires an AbortController
# and surfaces a clean "OpenCode prompt timed out after Xms" error instead of
# letting undici trip its own headersTimeout. Increase this for slow upstream
# models (e.g. large combined resume+cover-letter prompts on gpt-5-nano).
# Default is 600000 (10 min). Min enforced is 1000 (1 s).
# OPENCODE_AI_PROMPT_TIMEOUT_MS=600000

# ===== OPTIONAL: OpenCode Client Lifecycle =====
# OPENCODE_CLIENT_KEEPALIVE controls whether the SDK's underlying fetch
# reuses TCP sockets across requests (RequestInit keepalive flag).
# Default is false — every prompt opens a fresh socket that closes after the
# response. This bounds socket usage on the OpenCode server's connection pool,
# which is the root cause of the "Headers Timeout Error" under load.
# Set to true only if you are certain the OpenCode server can handle the
# accumulated keep-alive sockets and you want the small per-request TCP
# savings. Not recommended for long-lived production deployments.
# OPENCODE_CLIENT_KEEPALIVE=false

# OPENCODE_CLIENT_ROTATE_AFTER forces a fresh SDK client (and its undici
# agent) every N requests, releasing the keep-alive pool. Combined with
# OPENCODE_CLIENT_KEEPALIVE=false this prevents the gradual socket
# accumulation that caused "after a while" failures.
# Default is 50. Set to 1 to rotate on every request (safest, slight TCP cost).
# OPENCODE_CLIENT_ROTATE_AFTER=50

# ===== OPTIONAL: Debug Routes =====
# Enables POST /generate/debug/slow-prompt for timeout validation. See
# AI_PROMPT_TIMEOUT_PLAN.md. Default is unset/false. Do NOT enable in prod.
# ENABLE_DEBUG_ROUTES=false
# OPENCODE_DEBUG_PROMPT_SLEEP_MS=0
