{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/gpt-5-nano",
  "provider": {
    "opencode-sdk": {
      "name": "OpenCode SDK"
    }
  },
  "permission": {
  },
  "mcp": {
    "codescene": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "@codescene/codehealth-mcp"],
      "environment": {
        "CS_ACCESS_TOKEN": "{env:CS_ACCESS_TOKEN}"
      }
    }
  }
}